{
  "permissions": {
    "deny": [
      "Bash(env)",
      "Bash(env:*)",
      "Bash(printenv)",
      "Bash(printenv:*)",
      "Bash(echo $*)",
      "Bash(printf $*)",
      "Bash(set)",
      "Bash(export -p)",
      "Bash(cat *identity.txt*)",
      "Bash(cat *.dec.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/redact-guard.sh"
          }
        ]
      }
    ]
  }
}
